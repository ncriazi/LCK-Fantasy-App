// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  email        String        @unique
  passwordHash String
  teams        FantasyTeam[]
  leagues      League[]      @relation("LeagueCommissioner")
}

model League {
  id                  String           @id @default(cuid())
  name                String
  inviteCode          String           @unique
  leagueSize          Int              @default(8)
  currentWeek         Int              @default(1)
  draftType           String           @default("snake")
  draftFormat         String           @default("normal")
  commissionerId      String
  commissioner        User             @relation("LeagueCommissioner", fields: [commissionerId], references: [id])
  teams               FantasyTeam[]
  isDrafted           Boolean          @default(false)
  draftStartedAt      DateTime?
  currentRound        Int?
  currentPickNumber   Int?
  currentTeamOnClockId String?
  currentTeamOnClock  FantasyTeam?     @relation("LeagueCurrentTeamOnClock", fields: [currentTeamOnClockId], references: [id])
  draftOrderEntries   DraftOrderEntry[]
  draftPicks          DraftPick[]
  waiverPriorities    WaiverPriority[]
  waiverClaims        WaiverClaim[]
  weeklyPlayerStates  WeeklyPlayerState[]
  weeklyDefenseStates WeeklyDefenseState[]
  weeklyTeamScores    WeeklyTeamScore[]
  tradeProposals      TradeProposal[]
}

model DraftOrderEntry {
  id           String      @id @default(cuid())
  leagueId     String
  league       League      @relation(fields: [leagueId], references: [id])
  teamId       String
  team         FantasyTeam @relation(fields: [teamId], references: [id])
  pickPosition Int

  @@unique([leagueId, pickPosition])
  @@unique([leagueId, teamId])
}

model DraftPick {
  id              String      @id @default(cuid())
  leagueId        String
  league          League      @relation(fields: [leagueId], references: [id])
  teamId          String
  team            FantasyTeam @relation(fields: [teamId], references: [id])
  round           Int
  overallPick     Int
  slot            String
  playerId        String?
  player          LckPlayer?  @relation(fields: [playerId], references: [id])
  organizationId  String?
  organization    LckOrganization? @relation(fields: [organizationId], references: [id])
  createdAt       DateTime    @default(now())

  @@unique([leagueId, overallPick])
}

model LckOrganization {
  id              String        @id @default(cuid())
  name            String        @unique
  players         LckPlayer[]
  defenseTeams    FantasyTeam[] @relation("DefenseOrganization")
  draftPicks      DraftPick[]
  waiverClaims    WaiverClaim[]
  weeklyStates    WeeklyDefenseState[]
  proposedTrades  TradeProposal[] @relation("TradeProposerOrganization")
  receivedTrades  TradeProposal[] @relation("TradeRecipientOrganization")
}

model LckPlayer {
  id             String            @id @default(cuid())
  name           String
  role           String
  organizationId String
  organization   LckOrganization   @relation(fields: [organizationId], references: [id])
  topTeams       FantasyTeam[]     @relation("TopPlayer")
  jungleTeams    FantasyTeam[]     @relation("JunglePlayer")
  midTeams       FantasyTeam[]     @relation("MidPlayer")
  botTeams       FantasyTeam[]     @relation("BotPlayer")
  supportTeams   FantasyTeam[]     @relation("SupportPlayer")
  draftPicks     DraftPick[]
  waiverClaims   WaiverClaim[]
  weeklyStates   WeeklyPlayerState[]
  proposedTrades TradeProposal[]   @relation("TradeProposerPlayer")
  receivedTrades TradeProposal[]   @relation("TradeRecipientPlayer")
}

model FantasyTeam {
  id                 String            @id @default(cuid())
  name               String
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  leagueId           String
  league             League            @relation(fields: [leagueId], references: [id])
  topPlayerId        String?
  topPlayer          LckPlayer?        @relation("TopPlayer", fields: [topPlayerId], references: [id])
  junglePlayerId     String?
  junglePlayer       LckPlayer?        @relation("JunglePlayer", fields: [junglePlayerId], references: [id])
  midPlayerId        String?
  midPlayer          LckPlayer?        @relation("MidPlayer", fields: [midPlayerId], references: [id])
  botPlayerId        String?
  botPlayer          LckPlayer?        @relation("BotPlayer", fields: [botPlayerId], references: [id])
  supportPlayerId    String?
  supportPlayer      LckPlayer?        @relation("SupportPlayer", fields: [supportPlayerId], references: [id])
  defenseOrgId       String?
  defenseOrg         LckOrganization?  @relation("DefenseOrganization", fields: [defenseOrgId], references: [id])
  draftOrderEntries  DraftOrderEntry[]
  clockLeagues       League[]          @relation("LeagueCurrentTeamOnClock")
  draftPicks         DraftPick[]
  waiverPriority     WaiverPriority?
  waiverClaims       WaiverClaim[]
  weeklyScores       WeeklyTeamScore[]
  proposedTrades     TradeProposal[]   @relation("TradeProposerTeam")
  receivedTrades     TradeProposal[]   @relation("TradeRecipientTeam")

  @@unique([userId, leagueId])
}

model WaiverPriority {
  id       String      @id @default(cuid())
  leagueId String
  league   League      @relation(fields: [leagueId], references: [id])
  teamId   String      @unique
  team     FantasyTeam @relation(fields: [teamId], references: [id])
  position Int

  @@unique([leagueId, teamId])
  @@unique([leagueId, position])
}

model WaiverClaim {
  id             String           @id @default(cuid())
  leagueId       String
  league         League           @relation(fields: [leagueId], references: [id])
  teamId         String
  team           FantasyTeam      @relation(fields: [teamId], references: [id])
  week           Int
  slot           String
  playerId       String?
  player         LckPlayer?       @relation(fields: [playerId], references: [id])
  organizationId String?
  organization   LckOrganization? @relation(fields: [organizationId], references: [id])
  status         String           @default("pending")
  resolutionNote String?
  processedAt    DateTime?
  createdAt      DateTime         @default(now())
}

model WeeklyPlayerState {
  id        String    @id @default(cuid())
  leagueId  String
  league    League    @relation(fields: [leagueId], references: [id])
  week      Int
  playerId  String
  player    LckPlayer @relation(fields: [playerId], references: [id])
  kills     Int       @default(0)
  assists   Int       @default(0)
  cs        Int       @default(0)
  visionScore Int     @default(0)
  played    Boolean   @default(false)
  points    Float     @default(0)

  @@unique([leagueId, week, playerId])
}

model WeeklyDefenseState {
  id             String          @id @default(cuid())
  leagueId       String
  league         League          @relation(fields: [leagueId], references: [id])
  week           Int
  organizationId String
  organization   LckOrganization @relation(fields: [organizationId], references: [id])
  towersAlive    Int             @default(0)
  played         Boolean         @default(false)
  points         Float           @default(0)

  @@unique([leagueId, week, organizationId])
}

model WeeklyTeamScore {
  id            String      @id @default(cuid())
  leagueId      String
  league        League      @relation(fields: [leagueId], references: [id])
  week          Int
  teamId        String
  team          FantasyTeam @relation(fields: [teamId], references: [id])
  topPoints     Float       @default(0)
  junglePoints  Float       @default(0)
  midPoints     Float       @default(0)
  botPoints     Float       @default(0)
  supportPoints Float       @default(0)
  defensePoints Float       @default(0)
  totalPoints   Float       @default(0)
  finalizedAt   DateTime?

  @@unique([leagueId, week, teamId])
}

model TradeProposal {
  id                      String           @id @default(cuid())
  leagueId                String
  league                  League           @relation(fields: [leagueId], references: [id])
  proposerTeamId          String
  proposerTeam            FantasyTeam      @relation("TradeProposerTeam", fields: [proposerTeamId], references: [id])
  recipientTeamId         String
  recipientTeam           FantasyTeam      @relation("TradeRecipientTeam", fields: [recipientTeamId], references: [id])
  proposerSlot            String
  proposerPlayerId        String?
  proposerPlayer          LckPlayer?       @relation("TradeProposerPlayer", fields: [proposerPlayerId], references: [id])
  proposerOrganizationId  String?
  proposerOrganization    LckOrganization? @relation("TradeProposerOrganization", fields: [proposerOrganizationId], references: [id])
  recipientSlot           String
  recipientPlayerId       String?
  recipientPlayer         LckPlayer?       @relation("TradeRecipientPlayer", fields: [recipientPlayerId], references: [id])
  recipientOrganizationId String?
  recipientOrganization   LckOrganization? @relation("TradeRecipientOrganization", fields: [recipientOrganizationId], references: [id])
  status                  String           @default("pending_recipient")
  createdAt               DateTime         @default(now())
  recipientRespondedAt    DateTime?
  commissionerReviewedAt  DateTime?
  completedAt             DateTime?
  commissionerNote        String?
}
